# =============================================================================
# Dandelions Investment Agent — Production Configuration Template
# =============================================================================
# Copy this file to .env and fill in real values before starting production.
# NEVER commit .env with real secrets to version control.
#
# Generate a secure JWT secret:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
#
# Generate a secure admin password:
#   python -c "import secrets; print(secrets.token_urlsafe(16))"
# =============================================================================

# --- LLM Configuration ---
DEEPSEEK_API_KEY=__REPLACE_WITH_YOUR_DEEPSEEK_API_KEY__
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL_FAST=deepseek-v4-flash
DEEPSEEK_MODEL_REASONING=deepseek-v4-pro
LLM_JSON_REPAIR_RETRIES=1

# --- Network / Proxy ---
MARKET_DATA_DISABLE_PROXY=true
DEEPSEEK_USE_PROXY=false
DEEPSEEK_HTTP_PROXY=

# --- Data Source ---
DEFAULT_DATA_SOURCE=qmt

# --- QMT Configuration ---
# Adjust paths to match your local QMT installation.
QMT_AUTO_DOWNLOAD=true
QMT_HISTORY_DAYS=1500
QMT_HISTORY_START=
QMT_HISTORY_END=
QMT_PERIOD=1d
QMT_DIVIDEND_TYPE=front
QMT_SUPPRESS_HELLO=true
QMT_PRICE_MAX_STALE_DAYS=3
QMT_STALE_REFRESH_DAYS=90
QMT_USE_FULL_TICK_FOR_STALE_PRICE=true
QMT_PRICE_AKSHARE_FALLBACK=true
QMT_FINANCIAL_AUTO_DOWNLOAD=false

# --- Industry Classification ---
INDUSTRY_CLASSIFICATION_PROVIDER=local_csmar
QMT_INDUSTRY_PROVIDER_EXPERIMENTAL=false
LOCAL_CSMAR_INDUSTRY_DB=storage/reference/csmar_industry.sqlite
LOCAL_CSMAR_INDUSTRY_LEVEL=CSMAR_ZX
LOCAL_CSMAR_INDUSTRY_UNIVERSE=sh_sz_bj
LOCAL_CSMAR_INDUSTRY_MIN_PEERS=20
LOCAL_CSMAR_INDUSTRY_FALLBACK_TO_SECTION=true
QMT_INDUSTRY_LEVEL=SW1
QMT_INDUSTRY_AUTO_DOWNLOAD=false
QMT_INDUSTRY_MIN_VALID_PEERS=20
QMT_INDUSTRY_PEER_CHUNK_SIZE=80
QMT_INDUSTRY_FINANCIAL_AUTO_DOWNLOAD=false
QMT_INDUSTRY_MAX_PE=300
QMT_INDUSTRY_MAX_PB=50
QMT_INDUSTRY_MAX_PS=100

# --- Peer Cache Preflight ---
QMT_PEER_CACHE_PREFLIGHT=true
QMT_PEER_CACHE_MIN_COVERAGE=0.8

# --- Share Capital Fallback ---
QMT_SHARE_CAPITAL_FALLBACK_PROVIDER=akshare
QMT_SHARE_CAPITAL_FALLBACK_MAX_SYMBOLS=50

# --- CSMAR Daily Derived ---
CSMAR_DAILY_DERIVED_PROVIDER=enabled
CSMAR_DAILY_DERIVED_DB=storage/reference/csmar_daily_derived_snapshots.sqlite
CSMAR_DAILY_DERIVED_MAX_STALE_DAYS=370
CSMAR_DAILY_DERIVED_VALUATION_MAX_STALE_DAYS=45

# --- CSMAR EVA Structure ---
CSMAR_EVA_STRUCTURE_PROVIDER=enabled
CSMAR_EVA_STRUCTURE_DB=storage/reference/csmar_eva_structure.sqlite
CSMAR_EVA_STRUCTURE_MAX_STALE_DAYS=460

# --- Research Cache ---
RESEARCH_CACHE_ENABLED=true
RESEARCH_CACHE_DB=storage/cache/research_data.sqlite

# --- Celery / Redis ---
# Point to your production Redis instance. docker-compose.yml provides a
# Redis 7 container with AOF persistence enabled.
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1

# --- JWT Authentication ---
# IMPORTANT: Generate a unique random value for production. Minimum 32 characters.
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=__REPLACE_WITH_RANDOM_32_PLUS_CHAR_STRING__
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
AUTH_REVOCATION_FAIL_MODE=open

# --- Rate Limiting / Proxy ---
# Only configure TRUSTED_PROXY_IPS behind a trusted reverse proxy.
TRUSTED_PROXY_IPS=
RATE_LIMIT_CLIENT_IP_HEADER=
CORS_ORIGINS=http://localhost:8501

# --- Admin Account ---
# IMPORTANT: Set a strong password for production. Do NOT use the example value.
AUTH_ADMIN_USER=admin
AUTH_ADMIN_PASS=__REPLACE_WITH_STRONG_ADMIN_PASSWORD__
