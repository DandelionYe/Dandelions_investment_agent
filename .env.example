DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL_FAST=deepseek-v4-flash
DEEPSEEK_MODEL_REASONING=deepseek-v4-pro

# 国内行情源建议直连。AKShare provider 会在当前进程内禁用代理。
MARKET_DATA_DISABLE_PROXY=true

# 如 DeepSeek 访问需要代理，可在本地 .env 中设置代理地址并由后续代码接入。
DEEPSEEK_USE_PROXY=false
DEEPSEEK_HTTP_PROXY=

# 生产数据源优先 QMT。没有 QMT 环境时用 --data-source mock 做离线验证。
DEFAULT_DATA_SOURCE=qmt

# QMT 行情接入。项目会先连接本机 QMT 服务，若本地日 K 为空则自动下载一次。
QMT_AUTO_DOWNLOAD=true
QMT_HISTORY_DAYS=420
QMT_HISTORY_START=
QMT_HISTORY_END=
QMT_PERIOD=1d
QMT_DIVIDEND_TYPE=front
QMT_SUPPRESS_HELLO=true

# QMT financial table download can be slow. Keep this false for stable startup;
# turn it on only when you want the project to fetch local financial tables.
QMT_FINANCIAL_AUTO_DOWNLOAD=false

# Local SQLite cache for provider logs and normalized snapshots.
RESEARCH_CACHE_ENABLED=true
RESEARCH_CACHE_DB=storage/cache/research_data.sqlite

# Celery / Redis
# 本地开发使用默认值；生产环境指向实际 Redis 实例。
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1

# JWT 认证
# 生产环境务必修改 JWT_SECRET 为随机字符串（可用 openssl rand -hex 32 生成）
JWT_SECRET=dandelions-dev-secret-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# 初始管理员用户（首次启动自动创建）
AUTH_ADMIN_USER=admin
AUTH_ADMIN_PASS=dandelions2026
