DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL_FAST=deepseek-v4-flash
DEEPSEEK_MODEL_REASONING=deepseek-v4-pro
LLM_JSON_REPAIR_RETRIES=1

# 国内行情源建议直连。AKShare provider 会在当前进程内禁用代理。
MARKET_DATA_DISABLE_PROXY=true

# 如 DeepSeek 访问需要代理，可在本地 .env 中设置代理地址并由后续代码接入。
DEEPSEEK_USE_PROXY=false
DEEPSEEK_HTTP_PROXY=

# 国内新闻/政策/舆情增强源。默认关闭；启用后代码层会强制禁用代理，
# 避免用户开启 VPN 时影响东方财富、新浪财经、新华网、澎湃、B站、抖音、百度新闻等国内接口。
# GitHub/Google 等非国内热榜源也会遵循该直连策略，失败时只作为可隔离 fallback 记录。
WEB_NEWS_ENABLED=false
WEB_NEWS_FORCE_NO_PROXY=true
WEB_NEWS_SOURCES=eastmoney,sina,xinhuanet,hotrank,baidu
WEB_NEWS_EASTMONEY_URL=https://search-api-web.eastmoney.com/search/jsonp
WEB_NEWS_SINA_ROLL_URL=https://finance.sina.com.cn/roll/
WEB_NEWS_XINHUANET_URL=http://qc.wa.news.cn/nodeart/list
WEB_NEWS_HOTRANK_SOURCES=wallstreetcn,yicai,36kr,tencent,sina_news,sina_hot,pengpai,bilibili,douyin,csdn,github,google,weread
WEB_NEWS_PENGPAI_HOT_URL=https://cache.thepaper.cn/contentapi/wwwIndex/rightSidebar
WEB_NEWS_BILIBILI_RANKING_URL=https://api.bilibili.com/x/web-interface/ranking/v2
WEB_NEWS_DOUYIN_HOT_URL=https://www.douyin.com/aweme/v1/web/hot/search/list/
WEB_NEWS_DOUYIN_HOME_URL=https://www.douyin.com/
WEB_NEWS_WALLSTREETCN_HOT_URL=https://api-one-wscn.awtmt.com/apiv1/content/articles/hot?period=all
WEB_NEWS_WEREAD_RANK_URL=https://weread.qq.com/web/bookListInCategory/rising?rank=1
WEB_NEWS_36KR_HOT_URL=https://www.36kr.com/hot-list/renqi/
WEB_NEWS_CSDN_HOT_URL=https://blog.csdn.net/phoenix/web/blog/hot-rank?page=0&pageSize=25&type=
WEB_NEWS_YICAI_HOT_URL=https://www.yicai.com/api/ajax/getranklistbykeys?keys=newsRank%2CvideoRank%2CimageRank%2CliveRank
WEB_NEWS_GITHUB_TRENDING_URL=https://github.com/trending
WEB_NEWS_GOOGLE_TRENDS_URL=https://trends.google.com/trends/api/realtimetrends?hl=zh-CN&tz=-480&cat=all&fi=0&fs=0&geo=US&ri=300&rs=20&sort=0
WEB_NEWS_TENCENT_HOT_URL=https://r.inews.qq.com/gw/event/pc_hot_ranking_list?ids_hash=&offset=0&page_size=50
WEB_NEWS_SINA_HOT_URL=https://sinanews.sina.cn/h5/top_news_list.d.html
WEB_NEWS_SINA_NEWS_TOP_URL=https://top.finance.sina.com.cn/ws/GetTopDataList.php
WEB_NEWS_BAIDU_RSS_URL=https://news.baidu.com/ns
WEB_NEWS_LIMIT=10
WEB_NEWS_TIMEOUT_SECONDS=8
WEB_NEWS_EXTRA_KEYWORDS=

# 生产数据源优先 QMT。没有 QMT 环境时用 --data-source mock 做离线验证。
DEFAULT_DATA_SOURCE=qmt

# QMT 行情接入。项目会先连接本机 QMT 服务，若本地日 K 为空则自动下载一次。
QMT_AUTO_DOWNLOAD=true
QMT_HISTORY_DAYS=1500  # 约 6 年日线，确保 PE/PB 历史分位有足够样本（≥250）
QMT_HISTORY_START=
QMT_HISTORY_END=
QMT_PERIOD=1d
QMT_DIVIDEND_TYPE=front
QMT_SUPPRESS_HELLO=true

# QMT financial table download can be slow. Keep this false for stable startup;
# turn it on only when you want the project to fetch local financial tables.
QMT_FINANCIAL_AUTO_DOWNLOAD=false

# QMT industry cross-sectional valuation. Applies to A-share stocks only; ETFs skip it.
QMT_INDUSTRY_LEVEL=SW1
QMT_INDUSTRY_AUTO_DOWNLOAD=true
QMT_INDUSTRY_MIN_VALID_PEERS=20
QMT_INDUSTRY_PEER_CHUNK_SIZE=80
QMT_INDUSTRY_FINANCIAL_AUTO_DOWNLOAD=false
QMT_INDUSTRY_MAX_PE=300
QMT_INDUSTRY_MAX_PB=50
QMT_INDUSTRY_MAX_PS=100

# Local SQLite cache for provider logs and normalized snapshots.
RESEARCH_CACHE_ENABLED=true
RESEARCH_CACHE_DB=storage/cache/research_data.sqlite

# Celery / Redis
# 本地开发使用默认值；生产环境指向实际 Redis 实例。
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1

# JWT 认证
# 生产环境务必修改 JWT_SECRET 为 32 字符以上随机字符串：
# python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-use-secrets-token-urlsafe-48-or-longer
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
AUTH_REVOCATION_FAIL_MODE=open

# Rate limiter proxy handling. Only set these behind a trusted reverse proxy.
TRUSTED_PROXY_IPS=
RATE_LIMIT_CLIENT_IP_HEADER=
CORS_ORIGINS=http://localhost:8501

# 初始管理员用户（首次启动自动创建）
AUTH_ADMIN_USER=admin
AUTH_ADMIN_PASS=dandelions2026
